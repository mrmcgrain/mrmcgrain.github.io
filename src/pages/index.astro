---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Candidate Assessment Platform',
    description:
      'Certification-style testing suite with randomized questions, timing, completion reporting, and attention monitoring.',
    tags: ['JavaScript', 'HTML5', 'CSS3', 'GitHub Pages'],
    variant: 'dashboard',
    image: '/images/ciw-test-thumbnail.png',
    url: 'https://mrmcgrain.github.io/ciwTEST/',
    breakdown: [
      'Built as a certification-style testing station for student practice and assessment.',
      'Randomizes 100-question sessions across multiple learning pathways.',
      'Supports new assessments by adding a structured JSON file of questions, answers, and scoring data.',
      'Tracks progress, timing, completion state, and final scoring.',
      'Records attention events such as tab or window changes during a session.',
      'Uses Google Apps Script with Sheets integration to collect and review submitted results.',
      'Hosted on GitHub Pages for easy access and live demonstration.',
    ],
  },
  {
    title: 'Dare to Dream',
    description:
      'Immersive, scroll-driven studio website with interactive storytelling, clear service paths, and responsive project inquiry.',
    tags: ['Interactive Design', '3D', 'Responsive UI', 'GitHub Pages'],
    variant: 'site',
    image: '/images/dare-to-dream-thumbnail.png',
    url: 'https://mrmcgrain.github.io/WebsitesDemo/sites/daretodream-dev/',
  },
  {
    title: 'CodeCraftsMan Scroll World',
    description:
      'A continuous, scroll-driven cinematic journey through a digital forge and strategy chamber, built to turn systems thinking into an immersive visual story.',
    tags: ['Scroll Experience', 'Cinematic UI', '3D Art Direction', 'GitHub Pages'],
    image: '/images/codecraftsman-forge-entrance-thumbnail.png',
    imageHover: '/images/codecraftsman-strategy-chamber-thumbnail.png',
    viewingNote: 'Desktop recommended — use a full-size browser and scroll slowly for the complete effect.',
    url: 'https://mrmcgrain.github.io/WebsitesDemo/sites/codecraftsman-scroll-world/',
  },
  {
    title: 'Oceanside Property Care',
    description: 'Responsive coastal property-care website focused on local trust, clear services, and quote generation.',
    tags: ['Responsive Design', 'HTML5', 'CSS3'],
    image: '/images/oceanside-property-care-house-thumbnail.png',
    url: 'https://mrmcgrain.github.io/WebsitesDemo/sites/oceanside-property-care-premium-mockup/',
  },
  {
    title: '8001 Nails & Spa',
    description:
      'Responsive salon website built around polished service presentation, customer trust, and frictionless booking actions.',
    tags: ['Local Business', 'Responsive Design', 'Conversion UX', 'GitHub Pages'],
    image: '/images/8001-nails-spa-thumbnail.png',
    url: 'https://mrmcgrain.github.io/WebsitesDemo/sites/8001nail/',
  },
  {
    title: 'The Paw Spa — Ahwatukee',
    description:
      'Warm, responsive dog-grooming website focused on gentle care, local trust, clear service information, and appointment requests.',
    tags: ['Local Business', 'Responsive Design', 'Booking UX', 'GitHub Pages'],
    image: '/images/paw-spa-ahwatukee-thumbnail.png',
    url: 'https://mrmcgrain.github.io/WebsitesDemo/sites/the-paw-spa-ahwatukee/',
  },
];

const skillGroups = [
  ['Languages', ['JavaScript ES6+', 'TypeScript', 'Python', 'HTML5', 'CSS3']],
  ['Frontend', ['React.js', 'Next.js', 'Tailwind CSS', 'Responsive UI', 'Redux', 'Context API']],
  [
    'Backend',
    [
      'Node.js',
      'Express.js',
      'RESTful APIs',
      'JWT Authentication',
      'MongoDB',
      'PostgreSQL',
      'Socket.io',
    ],
  ],
  ['DevOps & Tools', ['Git', 'GitHub', 'Docker', 'Linux', 'CI/CD Pipelines']],
  ['Accessibility', ['WCAG 2.2 AA', 'Title II ADA Compliance']],
  [
    'AI & Automation',
    [
      'GitHub Copilot',
      'OpenAI Codex',
      'Claude Code',
      'Hermes Agent Harness',
      'Prompt Engineering',
    ],
  ],
  [
    'Security & Infrastructure',
    [
      'Web Security',
      'Secure Authentication',
      'Authorization',
      'Input Validation',
      'REST API Security',
      'Network Security',
      'Linux Environments',
      'Systems Engineering',
      'Networking',
    ],
  ],
];
---

<BaseLayout
  title="Michael Ryan McGrain | Full Stack Software Engineer"
  description="Portfolio for Michael Ryan McGrain, a full-stack software engineer focused on AI-assisted development, accessible web applications, security, and technical systems."
>
  <main>
    <section class="hero" id="top">
      <header class="nav-shell">
        <a class="brand" href="#top" aria-label="Michael McGrain home">
          <img class="brand-monogram" src="/images/mm-monogram.png" alt="" width="45" height="28" />
          <strong>Michael McGrain</strong>
        </a>
        <nav aria-label="Primary navigation">
          <a class="active" href="#work">Work</a>
          <a href="#about">About</a>
          <a href="#skills">Skills</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Software Engineer - MERN Instructor - AI Builder</p>
          <h1>Dare to Dream</h1>
          <p class="hero-lede">
            I build accessible full-stack applications, AI-assisted workflows, and secure web
            systems with the kind of visual polish clients remember.
          </p>
          <div class="hero-actions">
            <a class="primary-action" href="#work">View Projects <span aria-hidden="true">-></span></a>
            <a
              class="secondary-action"
              href="https://mail.google.com/mail/?view=cm&fs=1&to=michael.r.mcgrain%40gmail.com&su=Portfolio%20Inquiry"
              target="_blank"
              rel="noreferrer"
            >
              Contact Me
            </a>
          </div>
          <ul class="hero-traits" aria-label="Core strengths">
            <li><span aria-hidden="true">&lt;/&gt;</span> Clean Code</li>
            <li><span aria-hidden="true">[]</span> Technical Instructor</li>
            <li><span aria-hidden="true">*</span> AI Explorer</li>
          </ul>
        </div>

        <div class="signal-stage" aria-label="Abstract technical signal visualization">
          <img
            class="signal-art"
            src="/images/signal-stage-reference.png"
            alt=""
            width="577"
            height="356"
          />
        </div>
      </div>
    </section>

    <section class="content-band" id="work">
      <div class="section-wrap">
        <div class="section-heading">
          <div class="number-title">
            <span>01</span>
            <h2>Selected Work</h2>
          </div>
          <a href="#contact">View all projects <span aria-hidden="true">-></span></a>
        </div>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                {
                  project.image ? (
                    project.url ? (
                      <a
                        class="project-link"
                        href={project.url}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={`Open ${project.title}`}
                      >
                        <span class:list={['project-thumbnail-stack', { 'has-alternate': project.imageHover }]}>
                          <picture>
                            {project.imageMobile && <source media="(max-width: 720px)" srcset={project.imageMobile} />}
                            {project.imageTablet && <source media="(max-width: 980px)" srcset={project.imageTablet} />}
                            <img
                              class="project-thumbnail"
                              src={project.image}
                              alt=""
                              width="1440"
                              height="900"
                            />
                          </picture>
                          {
                            project.imageHover && (
                              <img
                                class="project-thumbnail project-thumbnail-alternate"
                                src={project.imageHover}
                                alt=""
                                width="1264"
                                height="608"
                              />
                            )
                          }
                        </span>
                      </a>
                    ) : (
                      <img
                        class="project-thumbnail"
                        src={project.image}
                        alt=""
                        width="1014"
                        height="488"
                      />
                    )
                  ) : (
                    <div class={`project-preview ${project.variant}`} aria-hidden="true">
                      <div class="preview-top">
                        <span></span>
                        <span></span>
                        <span></span>
                      </div>
                      <div class="preview-body">
                        <span class="preview-sidebar"></span>
                        <div class="preview-main">
                          <span></span>
                          <span></span>
                          <span></span>
                        </div>
                      </div>
                    </div>
                  )
                }
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                {
                  project.viewingNote && (
                    <p class="project-viewing-note">
                      <svg aria-hidden="true" viewBox="0 0 24 24">
                        <path d="M3 4.5h18v12H3v-12Zm2 2v8h14v-8H5Zm4 12h6v1.5H9v-1.5Z" />
                      </svg>
                      {project.viewingNote}
                    </p>
                  )
                }
                <ul>
                  {project.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
                {
                  project.breakdown && (
                    <details class="project-details">
                      <summary>
                        Project Details
                        <svg aria-hidden="true" viewBox="0 0 24 24">
                          <path d="m6.7 8.8 5.3 5.4 5.3-5.4 1.4 1.4-6.7 6.8-6.7-6.8 1.4-1.4Z" />
                        </svg>
                      </summary>
                      <div>
                        {project.breakdown.map((item) => (
                          <p>{item}</p>
                        ))}
                      </div>
                    </details>
                  )
                }
              </article>
            ))
          }
        </div>

        <section class="demo-links" aria-labelledby="demo-links-title">
          <div>
            <span>Website demos</span>
            <h3 id="demo-links-title">Live website demo links</h3>
          </div>
          <a href="https://mrmcgrain.github.io/WebsitesDemo/" target="_blank" rel="noreferrer">
            WebsitesDemo <span aria-hidden="true">-></span>
          </a>
        </section>

        <div class="about-skills-grid">
          <section class="about-block" id="about">
            <div class="number-title">
              <span>02</span>
              <h2>About Me</h2>
            </div>
            <p>
              I&apos;m a Full-Stack Software Engineer and Technical Instructor with more than 17 years
              of experience across software development, systems engineering, networking,
              infrastructure, and secure technology operations.
            </p>
            <p>
              I build modern, accessible web applications using the MERN stack, with a focus on
              clean architecture, responsive design, RESTful APIs, WCAG 2.2 accessibility, and secure
              development practices. My work includes authentication and authorization, input
              validation, API security, CI/CD workflows, and deployment in Linux-based environments.
            </p>
            <p>
              I also use AI-assisted development tools to improve productivity, accelerate
              problem-solving, and build practical solutions. I&apos;m a strong advocate that AI is not a
              crutch nor replacement for our code, but a peer programmer. As an instructor and
              mentor, I enjoy helping others grow their technical skills while creating technology
              that supports businesses, learners, and meaningful community impact.
            </p>
            <ul class="about-points">
              <li>
                <span aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 2.5a7.1 7.1 0 0 0-7.1 7.1c0 5.3 7.1 11.9 7.1 11.9s7.1-6.6 7.1-11.9A7.1 7.1 0 0 0 12 2.5Zm0 9.7a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2Z"
                    />
                  </svg>
                </span>
                Phoenix, Arizona
              </li>
              <li><span aria-hidden="true">&lt;/&gt;</span> JavaScript / MERN</li>
              <li><span aria-hidden="true">*</span> AI-focused builder</li>
            </ul>
          </section>

          <section class="skills-block" id="skills">
            <div class="number-title">
              <span>03</span>
              <h2>Skills</h2>
            </div>
            <div class="skill-list">
              {
                skillGroups.map(([label, skills]) => (
                  <div class="skill-row">
                    <strong>{label}</strong>
                    <div>
                      {(skills as string[]).map((skill) => (
                        <span>{skill}</span>
                      ))}
                    </div>
                  </div>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="cta" id="contact">
      <div class="cta-inner">
        <div>
          <div class="number-title">
            <span>04</span>
            <h2>Let&apos;s turn your dreams into a reality</h2>
          </div>
          <p>Have a project in mind, a role to discuss, or a system that needs a stronger shape?</p>
        </div>
        <a
          class="contact-button"
          href="https://mail.google.com/mail/?view=cm&fs=1&to=michael.r.mcgrain%40gmail.com&su=Portfolio%20Inquiry"
          target="_blank"
          rel="noreferrer"
        >
          Get In Touch
        </a>
        <div class="social-links" aria-label="Social links">
          <a href="https://github.com/mrmcgrain" aria-label="GitHub" target="_blank" rel="noreferrer">
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path
                d="M12 .7a11.3 11.3 0 0 0-3.6 22c.6.1.8-.2.8-.6v-2c-3.4.7-4.1-1.5-4.1-1.5-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 .1.7 2.7 3.4 2 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.3-.1-.3-.5-1.6.1-3.3 0 0 1-.3 3.4 1.2a11.6 11.6 0 0 1 6.2 0c2.4-1.5 3.4-1.2 3.4-1.2.6 1.7.2 3 .1 3.3.8.9 1.2 2 1.2 3.3 0 4.7-2.8 5.7-5.5 6 .4.3.8 1 .8 2.1v3.2c0 .4.2.7.8.6A11.3 11.3 0 0 0 12 .7Z"
              />
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/michaelRmcgrain"
            aria-label="LinkedIn"
            target="_blank"
            rel="noreferrer"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path
                d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45Z"
              />
            </svg>
          </a>
          <a href="#contact" aria-label="Phone">
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path
                d="M6.6 2.5 9.2 8c.2.5.1 1.1-.3 1.5l-1.5 1.4a13.2 13.2 0 0 0 5.7 5.7l1.4-1.5c.4-.4 1-.5 1.5-.3l5.5 2.6c.6.3.9.9.8 1.6l-.5 3c-.1.7-.8 1.2-1.5 1.2A19.5 19.5 0 0 1 .8 3.7c0-.7.5-1.4 1.2-1.5l3-.5c.7-.1 1.3.2 1.6.8Z"
              />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 42rem;
    overflow: hidden;
    background:
      radial-gradient(circle at 76% 36%, rgba(127, 86, 255, 0.26), transparent 23rem),
      radial-gradient(circle at 86% 45%, rgba(72, 126, 255, 0.24), transparent 23rem),
      linear-gradient(135deg, #04060d 0%, #080a15 48%, #03050a 100%);
    color: #ffffff;
  }

  .hero::before,
  .hero::after {
    position: absolute;
    inset: -24%;
    z-index: 3;
    pointer-events: none;
    content: "";
    opacity: 0;
  }

  .hero::before {
    background:
      repeating-radial-gradient(circle at 17% 41%, rgba(255, 255, 255, 0.72) 0 1px, transparent 1px 5px),
      repeating-linear-gradient(92deg, rgba(255, 255, 255, 0.32) 0 1px, transparent 1px 7px),
      linear-gradient(105deg, transparent 0 35%, rgba(255, 255, 255, 0.9) 44%, transparent 55% 100%);
    background-size: 5rem 5rem, 17rem 100%, 180% 100%;
    mix-blend-mode: screen;
    transform: scale(1.7) rotate(-7deg);
    filter: blur(0.7px) contrast(1.65);
    animation: hero-signal-snow 10s steps(1, end) infinite;
    animation-delay: 1s;
  }

  .hero::after {
    background:
      linear-gradient(108deg, transparent 0 38%, rgba(255, 255, 255, 0.8) 39%, transparent 42%),
      linear-gradient(111deg, transparent 0 52%, rgba(172, 219, 255, 0.42) 53%, transparent 58%);
    mix-blend-mode: color-dodge;
    transform: translateX(-38%) skewX(-18deg) scale(1.9);
    filter: blur(9px);
    animation: hero-signal-tear 10s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
    animation-delay: 1s;
  }

  @keyframes hero-signal-snow {
    0% {
      opacity: 0.2;
      background-position: 2rem -1rem, 9rem 0, 48% 0;
    }

    0.45% {
      opacity: 0.06;
      background-position: -3rem 4rem, -7rem 0, 52% 0;
    }

    0.9% {
      opacity: 0.34;
      background-position: 6rem 2rem, 14rem 0, 56% 0;
    }

    1.35% {
      opacity: 0.08;
      background-position: -5rem -2rem, -11rem 0, 42% 0;
    }

    2%,
    100% {
      opacity: 0;
      background-position: 0 0, 0 0, 0 0;
    }
  }

  @keyframes hero-signal-tear {
    0% {
      opacity: 0.16;
      transform: translateX(-18%) skewX(-18deg) scale(1.9);
    }

    0.9% {
      opacity: 0.5;
      transform: translateX(9%) skewX(-18deg) scale(1.9);
    }

    1.75% {
      opacity: 0.1;
      transform: translateX(29%) skewX(-18deg) scale(1.9);
    }

    2.6%,
    100% {
      opacity: 0;
      transform: translateX(-38%) skewX(-18deg) scale(1.9);
    }
  }

  .nav-shell,
  .hero-inner,
  .section-wrap,
  .cta-inner {
    width: min(1200px, calc(100% - 48px));
    margin-inline: auto;
  }

  .nav-shell {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.6rem 0;
  }

  .brand,
  nav,
  .hero-actions,
  .hero-traits,
  .number-title,
  .section-heading,
  .about-points,
  .cta-inner,
  .social-links {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 1rem;
    font-size: 1rem;
  }

  .brand-monogram {
    display: block;
    width: 2.8rem;
    height: auto;
    filter: drop-shadow(0 0 18px rgba(255, 255, 255, 0.12));
  }

  .brand strong {
    font-size: clamp(1rem, 2vw, 1.18rem);
  }

  nav {
    gap: clamp(1rem, 3vw, 2.25rem);
  }

  nav a {
    position: relative;
    color: rgba(255, 255, 255, 0.86);
    font-weight: 650;
  }

  nav a.active::after,
  nav a:hover::after {
    position: absolute;
    right: 0;
    bottom: -0.5rem;
    left: 0;
    height: 2px;
    border-radius: 99px;
    background: #8d6bff;
    content: "";
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(28rem, 0.95fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: center;
    min-height: 32rem;
    padding: 1.5rem 0 3.25rem;
  }

  .eyebrow {
    margin: 0;
    color: #a992ff;
    font-size: clamp(0.77rem, 1.4vw, 0.9rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 1rem 0 0;
    color: #ffffff;
    font-size: clamp(3.8rem, 8.5vw, 6.6rem);
    font-weight: 950;
    letter-spacing: 0;
    line-height: 0.94;
    text-wrap: balance;
  }

  .hero-lede {
    max-width: 590px;
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.45;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action,
  .contact-button {
    display: inline-flex;
    min-height: 3.45rem;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 7px;
    padding: 0.9rem 1.8rem;
    font-weight: 800;
  }

  .primary-action,
  .contact-button {
    background: linear-gradient(135deg, #8d6bff, #6f48e8);
    color: #ffffff;
    box-shadow: 0 16px 50px rgba(112, 72, 232, 0.35);
  }

  .secondary-action {
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: #ffffff;
  }

  .hero-traits {
    flex-wrap: wrap;
    gap: clamp(1rem, 3vw, 2.2rem);
    margin: 2rem 0 0;
    padding: 0;
    color: rgba(255, 255, 255, 0.76);
    list-style: none;
  }

  .hero-traits span {
    margin-right: 0.55rem;
    color: #9b76ff;
    font-weight: 950;
  }

  .signal-stage {
    position: relative;
    min-height: 30rem;
    isolation: isolate;
  }

  .signal-art {
    position: absolute;
    top: 50%;
    left: 50%;
    display: block;
    width: min(43rem, 92vw);
    max-width: none;
    height: auto;
    object-fit: contain;
    transform: translate(-48%, -50%);
    z-index: 2;
    filter: saturate(1.14) contrast(1.08) drop-shadow(0 0 44px rgba(101, 118, 255, 0.24));
    opacity: 0.98;
    animation: signal-art-pulse 7.5s ease-in-out infinite;
  }

  @keyframes signal-art-pulse {
    0%,
    100% {
      opacity: 0.88;
      filter: saturate(1.02) contrast(1.02) drop-shadow(0 0 24px rgba(101, 118, 255, 0.12));
      transform: translate(-48%, -50%) scale(0.984);
    }

    50% {
      opacity: 1;
      filter: saturate(1.3) contrast(1.16) drop-shadow(0 0 82px rgba(137, 110, 255, 0.54));
      transform: translate(-48%, -50%) scale(1.026);
    }
  }

  .content-band {
    background: #f7f8fb;
    color: #11131a;
    padding: 1.5rem 0 1.25rem;
  }

  .section-heading {
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-heading a {
    color: #7553e7;
    font-weight: 750;
  }

  .number-title {
    gap: 1.25rem;
  }

  .number-title span {
    color: #7d5cff;
    font-size: 1.1rem;
    font-weight: 950;
  }

  .number-title h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    line-height: 1.1;
  }

