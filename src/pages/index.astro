---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'MERN Teaching Platform',
    description: 'Course dashboard, code editor, quizzes, and progress tracking for full-stack students.',
    tags: ['MongoDB', 'Express', 'React', 'Node.js'],
    variant: 'dashboard',
  },
  {
    title: 'AI Study Companion',
    description: 'AI-powered study assistant for explanations, summaries, and guided Q&A.',
    tags: ['Next.js', 'OpenAI API', 'Tailwind CSS'],
    variant: 'chat',
  },
  {
    title: 'Local Business Website Kit',
    description: 'Fast-launch website template for small businesses and service brands.',
    tags: ['React', 'Vite', 'SEO'],
    variant: 'site',
  },
];

const skillGroups = [
  ['Frontend', ['JavaScript', 'TypeScript', 'React', 'Next.js', 'Astro', 'Tailwind CSS', 'HTML', 'CSS']],
  ['Backend', ['Node.js', 'Express', 'REST APIs', 'JWT', 'Socket.io']],
  ['Database', ['MongoDB', 'PostgreSQL', 'Mongoose']],
  ['AI & Tools', ['OpenAI API', 'Codex', 'Claude Code', 'GitHub Copilot', 'Docker', 'Linux']],
  ['Security', ['Auth', 'Authorization', 'Input Validation', 'API Security']],
];
---

<BaseLayout
  title="Michael Ryan McGrain | Full Stack Software Engineer"
  description="Portfolio for Michael Ryan McGrain, a full-stack software engineer focused on AI-assisted development, accessible web applications, security, and technical systems."
>
  <main>
    <section class="hero" id="top">
      <header class="nav-shell">
        <a class="brand" href="#top" aria-label="Michael McGrain home">
          <img class="brand-monogram" src="/images/mm-monogram.png" alt="" width="45" height="28" />
          <strong>Michael McGrain</strong>
        </a>
        <nav aria-label="Primary navigation">
          <a class="active" href="#work">Work</a>
          <a href="#about">About</a>
          <a href="#skills">Skills</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Software Engineer - MERN Instructor - AI Builder</p>
          <h1>Hello, I&apos;m Michael.</h1>
          <p class="hero-lede">
            I build accessible full-stack applications, AI-assisted workflows, and secure web
            systems with the kind of visual polish clients remember.
          </p>
          <div class="hero-actions">
            <a class="primary-action" href="#work">View Projects <span aria-hidden="true">-></span></a>
            <a class="secondary-action" href="mailto:michael.r.mcgrain@gmail.com">Contact Me</a>
          </div>
          <ul class="hero-traits" aria-label="Core strengths">
            <li><span aria-hidden="true">&lt;/&gt;</span> Clean Code</li>
            <li><span aria-hidden="true">[]</span> Teaching</li>
            <li><span aria-hidden="true">*</span> AI Explorer</li>
          </ul>
        </div>

        <div class="signal-stage" aria-label="Abstract technical signal visualization">
          <img
            class="signal-art"
            src="/images/signal-stage-reference.png"
            alt=""
            width="577"
            height="356"
          />
        </div>
      </div>
    </section>

    <section class="content-band" id="work">
      <div class="section-wrap">
        <div class="section-heading">
          <div class="number-title">
            <span>01</span>
            <h2>Selected Work</h2>
          </div>
          <a href="#contact">View all projects <span aria-hidden="true">-></span></a>
        </div>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <div class={`project-preview ${project.variant}`} aria-hidden="true">
                  <div class="preview-top">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <div class="preview-body">
                    <span class="preview-sidebar"></span>
                    <div class="preview-main">
                      <span></span>
                      <span></span>
                      <span></span>
                    </div>
                  </div>
                </div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <ul>
                  {project.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>

        <div class="about-skills-grid">
          <section class="about-block" id="about">
            <div class="number-title">
              <span>02</span>
              <h2>About Me</h2>
            </div>
            <p>
              I&apos;m a software engineer and coding instructor based in Phoenix, Arizona. My
              background spans full-stack web development, systems engineering, networking,
              security-minded implementation, and technical mentorship.
            </p>
            <ul class="about-points">
              <li><span aria-hidden="true">pin</span> Phoenix, Arizona</li>
              <li><span aria-hidden="true">&lt;/&gt;</span> JavaScript / MERN</li>
              <li><span aria-hidden="true">*</span> AI-focused builder</li>
            </ul>
          </section>

          <section class="skills-block" id="skills">
            <div class="number-title">
              <span>03</span>
              <h2>Skills</h2>
            </div>
            <div class="skill-list">
              {
                skillGroups.map(([label, skills]) => (
                  <div class="skill-row">
                    <strong>{label}</strong>
                    <div>
                      {(skills as string[]).map((skill) => (
                        <span>{skill}</span>
                      ))}
                    </div>
                  </div>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="cta" id="contact">
      <div class="cta-inner">
        <div>
          <div class="number-title">
            <span>04</span>
            <h2>Let&apos;s Build Something Great</h2>
          </div>
          <p>Have a project in mind, a role to discuss, or a system that needs a stronger shape?</p>
        </div>
        <a class="contact-button" href="mailto:michael.r.mcgrain@gmail.com">
          <span aria-hidden="true">mail</span>
          Get In Touch
        </a>
        <div class="social-links" aria-label="Social links">
          <a href="https://github.com/mrmcgrain" aria-label="GitHub">GH</a>
          <a href="https://linkedin.com/in/michaelRmcgrain" aria-label="LinkedIn">in</a>
          <a href="mailto:michael.r.mcgrain@gmail.com" aria-label="Email">@</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 42rem;
    overflow: hidden;
    background:
      radial-gradient(circle at 76% 36%, rgba(127, 86, 255, 0.26), transparent 23rem),
      radial-gradient(circle at 86% 45%, rgba(72, 126, 255, 0.24), transparent 23rem),
      linear-gradient(135deg, #04060d 0%, #080a15 48%, #03050a 100%);
    color: #ffffff;
  }

  .hero::before,
  .hero::after {
    position: absolute;
    inset: -24%;
    z-index: 3;
    pointer-events: none;
    content: "";
    opacity: 0;
  }

  .hero::before {
    background:
      repeating-radial-gradient(circle at 17% 41%, rgba(255, 255, 255, 0.72) 0 1px, transparent 1px 5px),
      repeating-linear-gradient(92deg, rgba(255, 255, 255, 0.32) 0 1px, transparent 1px 7px),
      linear-gradient(105deg, transparent 0 35%, rgba(255, 255, 255, 0.9) 44%, transparent 55% 100%);
    background-size: 5rem 5rem, 17rem 100%, 180% 100%;
    mix-blend-mode: screen;
    transform: scale(1.7) rotate(-7deg);
    filter: blur(0.7px) contrast(1.65);
    animation: hero-signal-snow 10s steps(1, end) infinite;
  }

  .hero::after {
    background:
      linear-gradient(108deg, transparent 0 38%, rgba(255, 255, 255, 0.8) 39%, transparent 42%),
      linear-gradient(111deg, transparent 0 52%, rgba(172, 219, 255, 0.42) 53%, transparent 58%);
    mix-blend-mode: color-dodge;
    transform: translateX(-38%) skewX(-18deg) scale(1.9);
    filter: blur(9px);
    animation: hero-signal-tear 10s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }

  @keyframes hero-signal-snow {
    0% {
      opacity: 0.2;
      background-position: 2rem -1rem, 9rem 0, 48% 0;
    }

    0.45% {
      opacity: 0.06;
      background-position: -3rem 4rem, -7rem 0, 52% 0;
    }

    0.9% {
      opacity: 0.34;
      background-position: 6rem 2rem, 14rem 0, 56% 0;
    }

    1.35% {
      opacity: 0.08;
      background-position: -5rem -2rem, -11rem 0, 42% 0;
    }

    2%,
    100% {
      opacity: 0;
      background-position: 0 0, 0 0, 0 0;
    }
  }

  @keyframes hero-signal-tear {
    0% {
      opacity: 0.16;
      transform: translateX(-18%) skewX(-18deg) scale(1.9);
    }

    0.9% {
      opacity: 0.5;
      transform: translateX(9%) skewX(-18deg) scale(1.9);
    }

    1.75% {
      opacity: 0.1;
      transform: translateX(29%) skewX(-18deg) scale(1.9);
    }

    2.6%,
    100% {
      opacity: 0;
      transform: translateX(-38%) skewX(-18deg) scale(1.9);
    }
  }

  .nav-shell,
  .hero-inner,
  .section-wrap,
  .cta-inner {
    width: min(1200px, calc(100% - 48px));
    margin-inline: auto;
  }

  .nav-shell {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.6rem 0;
  }

  .brand,
  nav,
  .hero-actions,
  .hero-traits,
  .number-title,
  .section-heading,
  .about-points,
  .cta-inner,
  .social-links {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 1rem;
    font-size: 1rem;
  }

  .brand-monogram {
    display: block;
    width: 2.8rem;
    height: auto;
    filter: drop-shadow(0 0 18px rgba(255, 255, 255, 0.12));
  }

  .brand strong {
    font-size: clamp(1rem, 2vw, 1.18rem);
  }

  nav {
    gap: clamp(1rem, 3vw, 2.25rem);
  }

  nav a {
    position: relative;
    color: rgba(255, 255, 255, 0.86);
    font-weight: 650;
  }

  nav a.active::after,
  nav a:hover::after {
    position: absolute;
    right: 0;
    bottom: -0.5rem;
    left: 0;
    height: 2px;
    border-radius: 99px;
    background: #8d6bff;
    content: "";
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(28rem, 0.95fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: center;
    min-height: 32rem;
    padding: 1.5rem 0 3.25rem;
  }

  .eyebrow {
    margin: 0;
    color: #a992ff;
    font-size: clamp(0.77rem, 1.4vw, 0.9rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin: 1rem 0 0;
    color: #ffffff;
    font-size: clamp(3.8rem, 8.5vw, 6.6rem);
    font-weight: 950;
    letter-spacing: 0;
    line-height: 0.94;
    text-wrap: balance;
  }

  .hero-lede {
    max-width: 590px;
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.45;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .primary-action,
  .secondary-action,
  .contact-button {
    display: inline-flex;
    min-height: 3.45rem;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 7px;
    padding: 0.9rem 1.8rem;
    font-weight: 800;
  }

  .primary-action,
  .contact-button {
    background: linear-gradient(135deg, #8d6bff, #6f48e8);
    color: #ffffff;
    box-shadow: 0 16px 50px rgba(112, 72, 232, 0.35);
  }

  .secondary-action {
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: #ffffff;
  }

  .hero-traits {
    flex-wrap: wrap;
    gap: clamp(1rem, 3vw, 2.2rem);
    margin: 2rem 0 0;
    padding: 0;
    color: rgba(255, 255, 255, 0.76);
    list-style: none;
  }

  .hero-traits span {
    margin-right: 0.55rem;
    color: #9b76ff;
    font-weight: 950;
  }

  .signal-stage {
    position: relative;
    min-height: 30rem;
    isolation: isolate;
  }

  .signal-art {
    position: absolute;
    top: 50%;
    left: 50%;
    display: block;
    width: min(43rem, 92vw);
    max-width: none;
    height: auto;
    object-fit: contain;
    transform: translate(-48%, -50%);
    z-index: 2;
    filter: saturate(1.14) contrast(1.08) drop-shadow(0 0 44px rgba(101, 118, 255, 0.24));
    opacity: 0.98;
  }

  .content-band {
    background: #f7f8fb;
    color: #11131a;
    padding: 1.5rem 0 1.25rem;
  }

  .section-heading {
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-heading a {
    color: #7553e7;
    font-weight: 750;
  }

  .number-title {
    gap: 1.25rem;
  }

  .number-title span {
    color: #7d5cff;
    font-size: 1.1rem;
    font-weight: 950;
  }

  .number-title h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    line-height: 1.1;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.75rem;
  }

  .project-card h3 {
    margin: 0.85rem 0 0.25rem;
    font-size: 1.08rem;
  }

  .project-card p {
    margin: 0;
    color: #3f4350;
    line-height: 1.45;
  }

  .project-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-card li,
  .skill-row span {
    border: 1px solid #d5d9e3;
    border-radius: 6px;
    background: #f8f9fb;
    color: #303542;
    font-size: 0.78rem;
    line-height: 1;
  }

  .project-card li {
    padding: 0.35rem 0.7rem;
  }

  .project-preview {
    overflow: hidden;
    border: 1px solid #d9dde8;
    border-radius: 8px;
    aspect-ratio: 2.08 / 1;
    background: linear-gradient(145deg, #11151f, #05070d);
    box-shadow: 0 18px 52px rgba(12, 18, 33, 0.17);
  }

  .preview-top {
    display: flex;
    gap: 0.35rem;
    padding: 0.75rem;
  }

  .preview-top span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #8d6bff;
  }

  .preview-body {
    display: grid;
    grid-template-columns: 24% 1fr;
    gap: 0.75rem;
    height: calc(100% - 2rem);
    padding: 0 0.75rem 0.75rem;
  }

  .preview-sidebar,
  .preview-main span {
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.07);
  }

  .preview-main {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.65rem;
  }

  .preview-main span:first-child {
    grid-column: 1 / -1;
    background: linear-gradient(90deg, rgba(141, 107, 255, 0.86), rgba(141, 107, 255, 0.14));
  }

  .chat .preview-main {
    grid-template-columns: 1fr;
  }

  .chat .preview-main span {
    width: 72%;
  }

  .chat .preview-main span:nth-child(2) {
    justify-self: end;
  }

  .site {
    background: #ffffff;
  }

  .site .preview-sidebar {
    background: #e9eef8;
  }

  .site .preview-main span {
    background: #dfe7f4;
  }

  .site .preview-main span:first-child {
    background: linear-gradient(90deg, #11131a 52%, #cfd9ea 52%);
  }

  .about-skills-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
    gap: 2.2rem;
    margin-top: 1.65rem;
    border-top: 1px solid #d9dde8;
    padding-top: 1rem;
  }

  .about-block {
    padding-right: 2rem;
  }

  .about-block p {
    max-width: 650px;
    margin: 0.8rem 0 0;
    color: #3f4350;
    line-height: 1.45;
  }

  .about-points {
    flex-wrap: wrap;
    gap: clamp(1rem, 3vw, 2.3rem);
    margin: 1.5rem 0 0;
    padding: 0;
    color: #3f4350;
    list-style: none;
  }

  .about-points span {
    margin-right: 0.5rem;
    color: #7d5cff;
    font-weight: 900;
  }

  .skills-block {
    border-left: 1px solid #d9dde8;
    padding-left: 2.2rem;
  }

  .skill-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .skill-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    align-items: start;
  }

  .skill-row strong {
    font-size: 0.86rem;
  }

  .skill-row div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .skill-row span {
    padding: 0.38rem 0.8rem;
  }

  .cta {
    background:
      radial-gradient(circle at 4% 16%, rgba(125, 92, 255, 0.16) 1px, transparent 1px),
      radial-gradient(circle at 96% 26%, rgba(125, 92, 255, 0.16) 1px, transparent 1px),
      #04060d;
    background-size: 1rem 1rem, 1rem 1rem, auto;
    color: #ffffff;
    padding: 2.3rem 0;
  }

  .cta-inner {
    justify-content: space-between;
    gap: 1.5rem;
  }

  .cta p {
    margin: 0.75rem 0 0 3.1rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .contact-button {
    gap: 0.75rem;
    min-width: min(18rem, 100%);
  }

  .social-links {
    gap: 0.9rem;
  }

  .social-links a {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 7px;
    color: #ffffff;
    font-weight: 900;
  }

  @media (max-width: 980px) {
    .hero {
      min-height: auto;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 4rem;
    }

    .signal-stage {
      min-height: 24rem;
    }

    .project-grid,
    .about-skills-grid {
      grid-template-columns: 1fr;
    }

    .skills-block {
      border-left: 0;
      border-top: 1px solid #d9dde8;
      padding: 1.25rem 0 0;
    }

    .about-block {
      padding-right: 0;
    }

    .cta-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .cta p {
      margin-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero::before,
    .hero::after {
      animation: none;
    }
  }

  @media (max-width: 720px) {
    .nav-shell,
    .hero-inner,
    .section-wrap,
    .cta-inner {
      width: min(100% - 28px, 1200px);
    }

    .nav-shell {
      align-items: flex-start;
      flex-direction: column;
      gap: 1.2rem;
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.65rem;
      overflow-x: auto;
      padding-bottom: 0.2rem;
      scrollbar-width: none;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    nav a {
      flex: 0 0 auto;
      font-size: 0.92rem;
    }

    .hero-inner {
      padding-top: 2rem;
      padding-bottom: 4rem;
    }

    .signal-stage {
      position: absolute;
      inset: 2.5rem -4.5rem auto -4.5rem;
      z-index: 0;
      min-height: 35rem;
      pointer-events: none;
    }

    .signal-art {
      top: 7rem;
      left: 50%;
      width: min(42rem, 168vw);
      opacity: 0.34;
      filter: saturate(1.18) contrast(1.05) blur(0.2px);
      transform: translate(-47%, 0);
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.98), rgba(0, 0, 0, 0.58) 56%, transparent 100%);
    }

    .hero-copy {
      position: relative;
      z-index: 1;
    }

    .hero-actions,
    .primary-action,
    .secondary-action,
    .contact-button {
      width: 100%;
    }

    .hero-traits {
      align-items: flex-start;
      flex-direction: column;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .project-grid {
      gap: 1.4rem;
    }

    .about-skills-grid {
      gap: 1.4rem;
    }

    .skill-row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }
  }

  @media (max-width: 430px) {
    .hero h1 {
      font-size: clamp(3.1rem, 18vw, 4rem);
    }

    .hero-lede {
      font-size: 1rem;
    }

    .number-title {
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
